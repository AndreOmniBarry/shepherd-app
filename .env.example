# ============================================================
# SHEP.HERD — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# ── Anthropic ────────────────────────────────────────────────
# From: console.anthropic.com → API Keys

ANTHROPIC_API_KEY=REDACTED

# ── JWT ──────────────────────────────────────────────────────
# Generate a random 32+ character string.
# Example: openssl rand -base64 32
# Change this before going to production.

JWT_SECRET=shepherd-dev-secret-CHANGE-this-before-production-32chars

# ── Performance (Mojave MacBook Air) ─────────────────────────
# Prevents Next.js dev server from eating all RAM on 4GB machines.

NODE_OPTIONS=--max-old-space-size=2048

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=SHEP.HERD
NEXT_PUBLIC_CHURCH_NAME=The Comforters House Global

# ── Absence-check cron ───────────────────────────────────────
# Required to call /api/care/trigger-alerts and trigger-midweek-alerts from
# an external scheduler (cron-job.org, Vercel Cron, etc). Generate a random
# string — without this set, those endpoints refuse every request.
CRON_SECRET=

# ── SMS (optional — leave blank until you have a provider) ───
# Once set, new-member welcome texts start sending automatically — no code
# changes needed. See src/lib/sms.ts.
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=SHEPHERD
